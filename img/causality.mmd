graph TD
    subgraph "Causality"
        A1["alice:0"] --> A2["alice:1"] --> A3["alice:2"]
        A1 --> B1["bob:0"]
    end

    subgraph "Happens-before (→)"
        H1["alice:0 → alice:1 → alice:2"]
        H2["alice:0 → bob:0"]
    end

    subgraph "Concurrent (∥)"
        C1["alice:1 ∥ bob:0"]
        C2["alice:2 ∥ bob:0"]
    end

    style A1 fill:#e8f0fe,stroke:#0078d4
    style A2 fill:#e8f0fe,stroke:#0078d4
    style A3 fill:#e8f0fe,stroke:#0078d4
    style B1 fill:#e6f4ea,stroke:#34a853
    style H1 fill:#f5f5f5,stroke:#999
    style H2 fill:#f5f5f5,stroke:#999
    style C1 fill:#fce8e6,stroke:#ea4335
    style C2 fill:#fce8e6,stroke:#ea4335
