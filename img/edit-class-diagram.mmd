classDiagram
    direction TB
    class Edit {
        <<abstract>>
        +transformSelector(sel)*
        +transform(prior) Edit
        +transformLaterConcurrentEdit(c) Edit
    }

    class NoOpOnRemovedTargetEdit {
        <<abstract>>
        handles deleted targets
    }

    class ListInsertEdit {
        <<abstract>>
        +node: Node
        +rewriteInsertedNode()
    }

    class UpdateTagEdit {
        overrides transformLaterConcurrentEdit
    }
    class WrapRecordEdit {
        overrides transformLaterConcurrentEdit
    }
    class WrapListEdit {
        overrides transformLaterConcurrentEdit
    }
    class RecordRenameFieldEdit {
        overrides transformSelector
    }
    class RecordDeleteEdit {
        overrides transformSelector
    }
    class ListPushFrontEdit {
        overrides transformSelector
    }

    class ListPushBackEdit
    class RecordAddEdit
    class SetEdit
    class ApplyPrimitiveEdit

    Edit <|-- NoOpOnRemovedTargetEdit
    NoOpOnRemovedTargetEdit <|-- ListInsertEdit
    NoOpOnRemovedTargetEdit <|-- UpdateTagEdit
    NoOpOnRemovedTargetEdit <|-- WrapRecordEdit
    NoOpOnRemovedTargetEdit <|-- WrapListEdit
    NoOpOnRemovedTargetEdit <|-- RecordRenameFieldEdit
    NoOpOnRemovedTargetEdit <|-- RecordDeleteEdit
    NoOpOnRemovedTargetEdit <|-- RecordAddEdit
    NoOpOnRemovedTargetEdit <|-- ApplyPrimitiveEdit
    ListInsertEdit <|-- ListPushBackEdit
    ListInsertEdit <|-- ListPushFrontEdit
