%%{init: {'themeVariables': {'fontFamily': 'monospace'}}}%%
graph TB
    E0["alice:0<br/>pushFront items<br/>(recorded)"]
    E1["alice:1<br/>copy input → !0<br/>(recorded)"]

    E2["alice:2<br/>pushFront items<br/>(later edit)"]

    R0["alice:3<br/>replay pushFront"]
    R1["alice:4<br/>replay copy → !0"]

    MERGE["alice:5<br/>merge"]

    E0 --> E1
    E1 --> E2
    E1 --> R0
    R0 --> R1
    R1 --> MERGE
    E2 --> MERGE

    style E0 fill:#e8f0fe,stroke:#0078d4,stroke-width:2px
    style E1 fill:#e8f0fe,stroke:#0078d4,stroke-width:2px
    style E2 fill:#e6f4ea,stroke:#34a853,stroke-width:2px
    style R0 fill:#fff4e5,stroke:#f5a623,stroke-width:2px
    style R1 fill:#fff4e5,stroke:#f5a623,stroke-width:2px
    style MERGE fill:#f3e8ff,stroke:#8b5cf6,stroke-width:2px
