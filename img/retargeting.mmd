graph TB
    S1["<pre style='text-align:left'>
<span style='color:#6e7781'>// list with two items</span>
{
  <span style='color:#0550ae'>$tag</span>: <span style='color:#0a3069'>'ul'</span>,
  <span style='color:#0550ae'>$children</span>: [
    <span style='color:#0a3069'>'John, john@ex.com'</span>,
    <span style='color:#0a3069'>'Ada, ada@ex.com'</span>
  ]
}
</pre>"]
    S2["<pre style='text-align:left'>
<span style='color:#6e7781'>// wrapList on each item (via wildcard)</span>
{
  <span style='color:#0550ae'>$tag</span>: <span style='color:#0a3069'>'ul'</span>,
  <span style='color:#0550ae'>$children</span>: [
    [<span style='color:#0a3069'>'John, john@ex.com'</span>],
    [<span style='color:#0a3069'>'Ada, ada@ex.com'</span>]
  ]
}
</pre>"]
    S3["<pre style='text-align:left'>
<span style='color:#6e7781'>// pushBack ref node to each row</span>
{
  <span style='color:#0550ae'>$tag</span>: <span style='color:#0a3069'>'ul'</span>,
  <span style='color:#0550ae'>$children</span>: [
    [<span style='color:#0a3069'>'John, john@ex.com'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#0a3069'>'../0'</span> }],
    [<span style='color:#0a3069'>'Ada, ada@ex.com'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#0a3069'>'../0'</span> }]
  ]
}
</pre>"]

    S1 -- "wrapList list/*" --> S2
    S2 -- "pushBack list/* (create ref ../0)" --> S3

    subgraph replay["Replay: Bob concurrently adds a third item"]
        S4["<pre style='text-align:left'>
{
  <span style='color:#0550ae'>$tag</span>: <span style='color:#0a3069'>'ul'</span>,
  <span style='color:#0550ae'>$children</span>: [
    [<span style='color:#0a3069'>'John, john@ex.com'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#0a3069'>'../0'</span> }],
    [<span style='color:#0a3069'>'Ada, ada@ex.com'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#0a3069'>'../0'</span> }],
    [<span style='color:#0a3069'>'Bob, bob@ex.com'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#cf222e'>???</span> }]
