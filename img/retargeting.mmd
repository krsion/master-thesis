graph TB
    S1["<pre style='text-align:left'>
// list with one item
['John, john@ex.com']
</pre>"]

    S2["<pre style='text-align:left'>
// value wrapped into sub-list
[['John, john@ex.com']]
</pre>"]

    S3["<pre style='text-align:left'>
// ref inserted before the value
[['../1', 'John, john@ex.com']]
</pre>"]

    S4["<pre style='text-align:left'>
// new item added to the front
['Ada, ada@ex.com',
 ['../1', 'John, john@ex.com']]
</pre>"]

    S1 -- "wrapList list/0" --> S2
    S2 -- "pushFront list/0 (ref ../1)" --> S3
    S3 -- "pushFront list ('Ada')" --> S4

    RL["<pre style='text-align:left'>
Loro: replay wrapList + pushFront ref on list/0

[[nodeId_abc, 'Ada'],
 [nodeId_abc, 'John']]

Both refs point to John! ❌
</pre>"]

    RC["<pre style='text-align:left'>
mydenicek: replay wrapList + pushFront ref on list/0

[['../1', 'Ada'],
 ['../1', 'John']]

Each ref points to its own row ✅
</pre>"]

    S4 --> RL
    S4 --> RC

    style RL fill:#fce8e6,stroke:#ea4335,stroke-width:2px
    style RC fill:#e6f4ea,stroke:#34a853,stroke-width:2px
