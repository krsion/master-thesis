%%{init: {'themeVariables': {'fontFamily': 'monospace'}}}%%
graph TB
    S1["<pre style='text-align:left'>
// list with one item
['John, john@ex.com']
</pre>"]

    S2["<pre style='text-align:left'>
// value wrapped into sub-list
[['John, john@ex.com']]
</pre>"]

    S1 -- "wrapList list/0" --> S2

    LORO1["<pre style='text-align:left'>
// Loro: absolute node ID
[[nodeId_abc, 'John, john@ex.com']]
</pre>"]

    CUSTOM1["<pre style='text-align:left'>
// mydenicek: relative path
[['../1', 'John, john@ex.com']]
</pre>"]

    S2 -- "pushFront list/0 (Loro)" --> LORO1
    S2 -- "pushFront list/0 (mydenicek)" --> CUSTOM1

    LORO2["<pre style='text-align:left'>
// add Ada to front of list
['Ada, ada@ex.com',
 [nodeId_abc, 'John, john@ex.com']]
</pre>"]

    CUSTOM2["<pre style='text-align:left'>
// add Ada to front of list
['Ada, ada@ex.com',
 ['../1', 'John, john@ex.com']]
</pre>"]

    LORO1 -- "pushFront list ('Ada')" --> LORO2
    CUSTOM1 -- "pushFront list ('Ada')" --> CUSTOM2

    RL["<pre style='text-align:left'>
Replay wrapList + pushFront ref on list/0

[[nodeId_abc, 'Ada'],
 [nodeId_abc, 'John']]

Both refs point to John! ❌
</pre>"]

    RC["<pre style='text-align:left'>
Replay wrapList + pushFront ref on list/0

[['../1', 'Ada'],
 ['../1', 'John']]

Each ref points to its own row ✅
</pre>"]

    LORO2 -- "replay on list/0" --> RL
    CUSTOM2 -- "replay on list/0" --> RC

    style RL fill:#fce8e6,stroke:#ea4335,stroke-width:2px
    style RC fill:#e6f4ea,stroke:#34a853,stroke-width:2px
    style LORO1 fill:#fce8e6,stroke:#ea4335,stroke-width:1px
    style CUSTOM1 fill:#e6f4ea,stroke:#34a853,stroke-width:1px
    style LORO2 fill:#fce8e6,stroke:#ea4335,stroke-width:1px
    style CUSTOM2 fill:#e6f4ea,stroke:#34a853,stroke-width:1px
