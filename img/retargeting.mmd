%%{init: {'themeVariables': {'fontFamily': 'monospace'}}}%%
graph TB
    S1["<pre style='text-align:left'>
<span style='color:#6e7781'>// list with one item</span>
[<span style='color:#0a3069'>'John, john@ex.com'</span>]
</pre>"]

    S2["<pre style='text-align:left'>
<span style='color:#6e7781'>// value wrapped into sub-list</span>
[[<span style='color:#0a3069'>'John, john@ex.com'</span>]]
</pre>"]

    S1 -- "wrapList list/0" --> S2

    subgraph diverge["Loro vs mydenicek: how is the ref stored?"]
        LORO["<pre style='text-align:left'>
<span style='color:#6e7781'>// Loro: absolute node ID</span>
[[<span style='color:#0a3069'>'John'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#cf222e'>nodeId_abc</span> }]]
</pre>"]
        CUSTOM["<pre style='text-align:left'>
<span style='color:#6e7781'>// mydenicek: relative path</span>
[[<span style='color:#0a3069'>'John'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#0a3069'>'../0'</span> }]]
</pre>"]
    end

    S2 -- "pushBack list/0 (ref to sibling)" --> diverge

    subgraph replayLoro["Replay wrapList + pushBack on list/1 (Loro)"]
        RL["<pre style='text-align:left'>
[[<span style='color:#0a3069'>'John'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#cf222e'>nodeId_abc</span> }],
 [<span style='color:#0a3069'>'Ada'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#cf222e'>nodeId_abc</span> }]]
<span style='color:#cf222e'>Both rows reference John! ❌</span>
</pre>"]
    end

    subgraph replayCustom["Replay wrapList + pushBack on list/1 (mydenicek)"]
        RC["<pre style='text-align:left'>
[[<span style='color:#0a3069'>'John'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#0a3069'>'../0'</span> }],
 [<span style='color:#0a3069'>'Ada'</span>, { <span style='color:#0550ae'>$ref</span>: <span style='color:#0a3069'>'../0'</span> }]]
<span style='color:#34a853'>Each row references itself ✅</span>
</pre>"]
    end

    LORO -- "replay wrapList + pushBack on list/1" --> RL
    CUSTOM -- "replay wrapList + pushBack on list/1" --> RC

    style RL fill:#fce8e6,stroke:#ea4335,stroke-width:2px
    style RC fill:#e6f4ea,stroke:#34a853,stroke-width:2px
